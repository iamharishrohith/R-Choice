    "db:push:kit": "npx drizzle-kit push",
    "env:verify": "node ./scripts/ops/verify-env.mjs",
    "secrets:generate": "node ./scripts/ops/generate-secrets.mjs",
    "launch:check": "npm run env:verify && npm run lint && npm run build",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui"
  },
